# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.pytest_cache/
.mypy_cache/

# Environments
.env
.venv
env/
venv/

# Local configuration (may contain secrets / machine-specific settings)
config.yaml

# Embedded Python / distributable build artifacts (generated)
py_embed_setup/embed_py311/
py_embed_setup/embed_py311.zip
templates/**/embed_py311/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Cursor (repo-local)
# Keep `.cursor/` tracked for repo-specific rules/commands/agents.
.cursor/audit-results/
.cursor/audit-results/**

# Kaggle/ML workflow outputs (directories only; avoid blanket file-type ignores)
data/
output/
outputs/
logs/
cache/
submissions/

# OS
.DS_Store
Thumbs.db

